{
	"name": "pnpm-config-dependency-action",
	"version": "0.9.0",
	"private": true,
	"description": "GitHub Action for updating pnpm config dependencies and regular dependencies with automated PR creation",
	"keywords": ["github-action", "pnpm", "config-dependencies", "dependency-updates", "monorepo", "changesets"],
	"homepage": "https://github.com/savvy-web/pnpm-config-dependency-action#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/pnpm-config-dependency-action/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/pnpm-config-dependency-action.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"build:prod": "github-action-builder build",
		"ci:build": "CI=\"true\" turbo run build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --pass-with-no-tests",
		"test:coverage": "vitest run --coverage --pass-with-no-tests",
		"test:watch": "vitest --watch --pass-with-no-tests",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit",
		"validate": "github-action-builder validate"
	},
	"dependencies": {
		"@actions/cache": "^4.1.0",
		"@actions/core": "^3.0.0",
		"@actions/exec": "^3.0.0",
		"@actions/github": "^9.0.0",
		"@actions/io": "^3.0.2",
		"@effect/platform": "^0.94.4",
		"@effect/platform-node": "^0.104.1",
		"@octokit/auth-app": "^8.2.0",
		"@pnpm/catalogs.config": "^1000.0.5",
		"@pnpm/catalogs.protocol-parser": "^1001.0.0",
		"@pnpm/lockfile.fs": "^1001.1.29",
		"@pnpm/lockfile.types": "^1002.0.9",
		"@pnpm/workspace.read-manifest": "^1000.3.0",
		"@savvy-web/github-action-effects": "^0.7.0",
		"effect": "^3.19.16",
		"workspace-tools": "^0.41.0",
		"yaml": "^2.8.2"
	},
	"devDependencies": {
		"@savvy-web/changesets": "^0.5.1",
		"@savvy-web/commitlint": "^0.4.1",
		"@savvy-web/github-action-builder": "^0.3.0",
		"@savvy-web/lint-staged": "^0.6.0",
		"@savvy-web/vitest": "^0.2.1"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.32.1",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	}
}
